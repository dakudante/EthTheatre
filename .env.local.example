# ─────────────────────────────────────────────────────────────
# ScreenRank environment
#
# The app runs out-of-the-box in DEMO MODE with bundled sample data
# when these are absent. Fill them in to connect a real Supabase
# project + TMDB and the data layer switches over automatically.
# ─────────────────────────────────────────────────────────────

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key — server only, used by admin write actions & seeding.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# TMDB (https://www.themoviedb.org/settings/api) — v4 read access token
TMDB_API_KEY=your-tmdb-v4-read-access-token
